{
  "name": "glide-tabs",
  "version": "0.1.0",
  "description": "An animated tab group component for React",
  "license": "MIT",
  "author": "Greg Ball",
  "repository": {
    "type": "git",
    "url": "https://github.com/gregball/glide-tabs"
  },
  "keywords": [
    "react",
    "tabs",
    "animated",
    "tab-group",
    "motion"
  ],
  "sideEffects": [
    "*.css"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup && cp src/styles.css dist/styles.css",
    "dev": "tsup --watch",
    "dev:website": "turbo run dev --filter=website",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "peerDependencies": {
    "motion": ">=11",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "motion": "^12.38.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tsup": "^8.5.1",
    "turbo": "^2.8.20",
    "typescript": "^6.0.2"
  }
}
